.container {
    max-width: 100%
}

@media (min-width: 640px) {
    .container {
        max-width:540px
    }
}

@media (min-width: 768px) {
    .container {
        max-width:768px
    }
}

@media (min-width: 1024px) {
    .container {
        max-width:1000px
    }
}

@media (min-width: 1280px) {
    .container {
        max-width:1250px
    }
}

