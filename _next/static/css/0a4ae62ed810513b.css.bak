        padding: 1rem
    }

    .landscape\:pb-0 {
        padding-bottom: 0
    }

    .landscape\:pb-8 {
        padding-bottom: 2rem
    }

    @media (min-width: 1024px) {
        .landscape\:lg\:pb-3 {
            padding-bottom:.75rem
        }
    }
}

.help-center li:before {
    display: none!important
}

.help-center img {
    display: block;
    margin: 2rem auto;
    max-width: 30rem
}

@media screen and (max-width: 767px) {
    .help-center img {
        max-width:100%
    }
}

.help-center h1 {
    font-size: 22px;
    margin: 0
}

.help-center img {
    justify-self: center
}

.help-center ul {
    display: grid
}

@media screen and (max-width: 767px) {
    .help-center ul {
        padding-left:2rem
    }
}

.help-center ul img {
    justify-self: center
}

.help-center li {
    font-weight: 300;
    line-height: 1.5rem
}

.admin-custom a {
    color: var(--primary)!important;
    display: inline
}

.admin-custom b,.admin-custom strong {
    color: var(--base)!important
}

.admin-custom li:before {
    display: inline-block;
    white-space: nowrap;
    width: 1.2em
}

.admin-custom li:not(.ql-direction-rtl):before {
    margin-left: -1.5em;
    margin-right: .3em;
    text-align: right
}

.admin-custom li.ql-direction-rtl:before {
    margin-left: .3em;
    margin-right: -1.5em
}

.admin-custom li.ql-indent-1:not(.ql-direction-rtl) {
    padding-left: 4.5em
}

.admin-custom li.ql-indent-1.ql-direction-rtl.ql-align-right {
    padding-right: 4.5em
}

.admin-custom li.ql-indent-2:not(.ql-direction-rtl) {
