.\[-webkit-text-stroke\:4px_var\(--primary\)\;\] {
    -webkit-text-stroke: 4px var(--primary)
}

body,html {
    background-color: var(--background);
    margin: 0;
    padding: 0
}

a,button {
    align-items: center;
    color: inherit;
    display: flex;
    text-decoration: none
}

* {
    box-sizing: border-box;
    color: var(--base)
}

.hide-scroll::-webkit-scrollbar {
    height: 0;
    width: 0
}

@media (max-width: 640px) {
    ::-webkit-scrollbar {
        height:3px;
        width: 3px
    }
}

::-webkit-scrollbar {
    background: transparent;
    height: 3px;
    width: 5px
}

::-webkit-scrollbar-thumb {
    background: var(--separator);
    border-radius: 10px
}

::-webkit-scrollbar-thumb:hover {
    opacity: .8
}

.opacity-scroll::-webkit-scrollbar {
    background: transparent;
    height: 3px;
    width: 5px
}

.opacity-scroll::-webkit-scrollbar-thumb {
    background: var(--secondaryBackground);
    border-radius: 10px
}

.admin-text a {
    display: inline
}

.admin-text a * {
    color: inherit
}

input::-webkit-inner-spin-button,input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0
}

input[type=number] {
    -moz-appearance: textfield
}

input[type=date] {
    -webkit-text-fill-color: var(--base)
}

progress::-webkit-progress-bar,progress::-webkit-progress-value {
    border-radius: 20px
}

.primary-progress::-webkit-progress-bar {
    background: var(--separator)
}

.primary-progress::-webkit-progress-value {
    background-color: var(--primary)
}

.warning-progress::-webkit-progress-value {
    background-color: #f90
}

.slide .control-dots {
    margin-left: 15px;
    text-align: left!important
}

@media (max-width: 640px) {
    .slide .control-dots {
        margin:0!important
    }

    .homebanner .carousel.carousel-slider {
        padding-bottom: 1.75rem!important
    }

    .homebanner .carousel .control-dots {
        padding-left: 10px!important;
        padding-right: 10px!important
    }
}

.homebanner .carousel.carousel-slider {
    padding-bottom: 2.75rem
}

.homebanner .carousel .control-dots {
    padding-left: 30px;
    padding-right: 30px
}

.slide .carousel .control-dots .dot {
    background: var(--background);
    margin: 0 5px;
    opacity: 1
}

@media (max-width: 640px) {
    .slide .carousel .control-next.control-arrow,.slide .carousel .control-prev.control-arrow {
        display:none
    }
}

.slide .slider-wrapper {
    border-radius: 0
}

.carousel.carousel-slider .control-arrow,.slide .carousel .control-arrow {
    transition: all .5s ease-in-out 0s
}

.slide .carousel .control-next.control-arrow,.slide .carousel .control-prev.control-arrow {
    bottom: 50px;
    top: 50px
}

.slide .carousel .control-prev.control-arrow {
    left: -10%
}

.slide .carousel .control-next.control-arrow {
    right: -10%
}

.slide .carousel:hover .control-prev.control-arrow {
    left: 0
}

.slide .carousel:hover .control-next.control-arrow {
    right: 0
}

.slide .carousel.carousel-slider .control-arrow:hover {
    background: none
}

.slide .carousel .control-prev.control-arrow:before {
    align-items: center;
    background-color: #fff;
    border-radius: 50%;
    border-right: none!important;
    box-shadow: 0 0 3px 0 #000;
    color: #7e869e;
    content: "<";
    display: flex;
    height: 45px;
    justify-content: center;
    opacity: .7;
    transition: all .5s ease-in-out 0s;
    width: 45px
}

.slide .carousel .control-prev.control-arrow:hover:before {
    opacity: 1
}

.slide .carousel .control-next.control-arrow:before {
    align-items: center;
    background-color: #fff;
    border-left: none!important;
    border-radius: 50%;
    box-shadow: 0 0 3px 0 #000;
    color: #7e869e;
    content: ">";
    display: flex;
    height: 45px;
    justify-content: center;
    opacity: .7;
    transition: all .5s ease-in-out 0s;
    width: 45px
}

.slide .carousel .control-next.control-arrow:hover:before {
    opacity: 1
}

.carousel-root.slide.togel {
    align-items: center;
    display: flex;
    height: 100%
}

.togel .carousel .control-prev.control-arrow {
    left: -30%
}

.togel .carousel .control-next.control-arrow {
    right: -30%
}

.togel .carousel.carousel-slider {
    padding-bottom: 20px
}

.togel .control-dots {
    margin: 0;
    text-align: center!important
}

.vip .left-arrow,.vip .right-arrow {
    background-color: #fff;
    box-shadow: 0 0 3px 0 #000;
    color: #7e869e;
    cursor: pointer;
    opacity: .7;
    transition: all .5s ease-in-out 0s;
    z-index: 50
}

.vip .right-arrow {
    right: -30%
}

.vip .left-arrow:hover,.vip .right-arrow:hover {
    opacity: 1
}

.vip .carousel:hover .right-arrow {
    right: .75rem
}

.vip .left-arrow {
    left: -30%
}

.vip .carousel:hover .left-arrow {
    left: .75rem
}

.vip .carousel .slider-wrapper {
    padding-top: 10px
}

.vip .carousel.carousel-slider {
    padding-bottom: 35px
}

@media (max-width: 640px) {
    .vip .carousel.carousel-slider {
        padding-bottom:20px
    }
}

.market-togel .carousel .slide img {
    width: auto!important
}

.market-togel .control-dots {
    display: none
}

.market-togel .carousel .slider-wrapper {
    padding: 10px 0
}

input:checked~.dot {
    background-color: var(--primary);
    transform: translateX(100%)
}

@keyframes rotate {
    to {
        transform: rotate(1turn)
    }
}

.rainbow {
    opacity: 1;
    overflow: hidden;
    position: absolute;
    z-index: 0
}

.rainbow:before {
    animation: rotate 3s linear infinite;
    background-image: linear-gradient(var(--primary),var(--primary)),linear-gradient(#ff8f1e,#ff8f1e),linear-gradient(var(--primary),var(--primary)),linear-gradient(#ff8f1e,#ff8f1e);
    background-position: 0 0,100% 0,100% 100%,0 100%;
    background-repeat: no-repeat;
    background-size: 50% 50%,50% 50%;
    content: "";
    height: 200%;
    left: -50%;
    position: absolute;
    top: -50%;
    width: 200%;
    z-index: -2
}

.track_drag {
    align-items: center;
    background-color: var(--tertiaryBackground);
    border-radius: 30px;
    display: flex;
    height: 55px;
    width: 100%
}

#item,.track_drag {
    overflow: hidden;
    touch-action: none
}

#item {
    background-color: var(--primary);
    background-image: url(data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTgiIGhlaWdodD0iMTYiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHBhdGggZD0iTTEgOGgxNk0xMCAxbDcgNy03IDciIHN0cm9rZT0iI2ZmZiIgc3Ryb2tlLXdpZHRoPSIyIiBzdHJva2UtbGluZWNhcD0icm91bmQiIHN0cm9rZS1saW5lam9pbj0icm91bmQiLz48L3N2Zz4=);
    background-position: 50%;
    background-repeat: no-repeat;
    background-size: 40% 40%;
    border: 1px solid hsla(0,0%,100%,.4);
    cursor: pointer;
    height: 45px;
    margin: 0 5px;
    -webkit-user-select: none;
    -moz-user-select: none;
    user-select: none;
    width: 45px;
    z-index: 999
}

#item,.track_text {
    border-radius: 30px
}

.track_text {
    align-items: center;
    color: var(--base);
    display: flex;
    height: 100%;
    justify-content: center;
    left: 0;
    margin: 0;
    position: absolute;
    top: 0;
    width: 100%
}

.track_text--before {
    border-radius: 30px;
    opacity: 1
}

.track_text--after,.track_text--end {
    border-radius: 30px;
    opacity: 0
}

.animate {
    transition: opacity .2s ease-in
}

.filter-bank {
    filter: grayscale(1) invert(56%) sepia(10%) saturate(720%) hue-rotate(187deg) brightness(92%) contrast(89%)
}

.filter-bank:hover {
    filter: none
}

@keyframes animateScroll {
    0%,15% {
        transform: translateY(0)
    }

    to {
        transform: translateY(44px)
    }
}

.rotateSpinWheel {
    animation: rotateSpinWheel 5s linear infinite
}

@keyframes rotateSpinWheel {
    0% {
        transform: rotate(0deg)
    }

    to {
        transform: rotate(5turn)
    }
}

.custom-fc-frame {
    color-scheme: "dark"
}

@media (orientation: landscape) {
    .landscape\:container {
        max-width:100%
    }

    @media (min-width: 640px) {
        .landscape\:container {
            max-width:540px
        }
    }

    @media (min-width: 768px) {
        .landscape\:container {
            max-width:768px
        }
    }

    @media (min-width: 1024px) {
        .landscape\:container {
            max-width:1000px
        }
    }

    @media (min-width: 1280px) {
        .landscape\:container {
            max-width:1250px
        }
    }
}

.last\:border-transparent:last-child {
    border-color: transparent
}

.even\:bg-background-default:nth-child(2n) {
    background-color: var(--background)
}

.focus-within\:border-primary:focus-within {
    border-color: var(--primary)
}

